{
  "name": "effect-sprite",
  "description": "Import a visual effect sprite sheet (gas, smoke, explosion, etc.) end-to-end. Default mode: produces a new fx/{name} prefab consumable by FxSpawner.Spawn (root + initially-inactive child with SpriteRenderer + SpriteAnimation MonoBehaviour with inline _frames), registered as fx/{name} in ResourcesDB. Merge mode (--target-fx fx/<existing-key>): adds a new variant child to an existing fx prefab — no new prefab, no new ResourcesDB entry; the variant is reachable as fx/<existing-key>#<child-name>.",
  "arguments": [
    { "name": "name", "required": true, "help": "Lowercase fx id (e.g. gas)" },
    { "name": "rows", "type": "int", "required": true, "help": "Sprite sheet rows" },
    { "name": "cols", "type": "int", "required": true, "help": "Sprite sheet columns" },
    { "name": "fps",  "type": "int", "default": 24, "help": "Animation FPS" },
    { "name": "loop", "default": "false", "choices": ["true", "false"], "help": "Loop the animation" },
    { "name": "sorting-layer", "type": "int", "default": 5 },
    { "name": "sorting-order", "type": "int", "default": 10 },
    { "name": "script-guid", "default": "", "help": "GUID of SpriteAnimation.cs (auto-detect if empty)" },
    { "name": "child-name", "default": "", "help": "Child GameObject m_Name (default: {name}_01)" },
    { "name": "target-fx", "default": "", "help": "When set (e.g. fx/SpriteSheetGas), merge as a child of that fx prefab instead of creating a new one" },
    { "name": "effect-img-dir", "default": "Assets/Images/Effects" },
    { "name": "effect-prefab-dir", "default": "Assets/Prefabs/Effects" },
    { "name": "resources-db", "default": "Assets/Prefabs/System/ResourcesDB.asset" }
  ],
  "steps": [
    { "type": "set-var", "var": "child_final",
      "value": "'{child_name}' if '{child_name}' else '{name}_01'", "eval": true },
    { "type": "set-var", "var": "merge_mode",
      "value": "'{target_fx}' != ''", "eval": true },
    {
      "type": "copy",
      "source": "{source}",
      "dest": "{unity_project}/{effect_img_dir}/{Name}/{Name}.png"
    },
    { "type": "await-meta", "path": "{unity_project}/{effect_img_dir}/{Name}/{Name}.png" },
    {
      "type": "run-script",
      "script": "unity-sprite-slicer/scripts/sprite_slicer.py",
      "args": ["slice", "{unity_project}/{effect_img_dir}/{Name}/{Name}.png", "{rows}", "{cols}"]
    },

    {
      "type": "run-script",
      "when": "{merge_mode}",
      "script": "import-asset/scripts/add_fx_child.py",
      "args": [
        "--target-fx", "{target_fx}",
        "--unity-project", "{unity_project}",
        "--resources-db", "{unity_project}/{resources_db}",
        "--child-name", "{child_final}",
        "--png", "{unity_project}/{effect_img_dir}/{Name}/{Name}.png",
        "--fps", "{fps}",
        "--loop", "{loop}",
        "--sorting-layer", "{sorting_layer}",
        "--sorting-order", "{sorting_order}"
      ]
    },

    {
      "type": "run-script",
      "when": "not {merge_mode}",
      "script": "import-asset/scripts/write_effect_prefab.py",
      "args": [
        "{unity_project}/{effect_prefab_dir}/{Name}/SpriteSheet{Name}.prefab",
        "{unity_project}/{effect_img_dir}/{Name}/{Name}.png",
        "--root-name", "SpriteSheet{Name}",
        "--child-name", "{child_final}",
        "--fps", "{fps}",
        "--loop", "{loop}",
        "--sorting-layer", "{sorting_layer}",
        "--sorting-order", "{sorting_order}",
        "--unity-project", "{unity_project}"
      ]
    },
    { "type": "await-meta",
      "when": "not {merge_mode}",
      "path": "{unity_project}/{effect_prefab_dir}/{Name}/SpriteSheet{Name}.prefab" },
    { "type": "read-meta",
      "when": "not {merge_mode}",
      "path": "{unity_project}/{effect_prefab_dir}/{Name}/SpriteSheet{Name}.prefab",
      "guid_var": "prefab_guid" },
    {
      "type": "text-insert",
      "when": "not {merge_mode}",
      "path": "{unity_project}/{resources_db}",
      "anchor": "(?m)^\\s*_entries:\\s*$",
      "marker": "key: fx/{name}\n",
      "insert": "\n  - key: fx/{name}\n    asset: {fileID: 100000, guid: {prefab_guid}, type: 3}"
    }
  ]
}
